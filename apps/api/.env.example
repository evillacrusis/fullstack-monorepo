NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/barberconnect?schema=public

# JWT — must be 32+ chars in production (use openssl rand -base64 32)
JWT_SECRET=change_me_to_a_random_32_char_secret_in_production
JWT_EXPIRY=15m
REFRESH_TOKEN_SECRET=change_me_to_a_random_32_char_secret_refresh
REFRESH_TOKEN_EXPIRY=7d

# CORS — comma separated list
ALLOWED_ORIGINS=http://localhost:3000
