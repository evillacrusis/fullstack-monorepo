{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@repo/contracts": ["../../packages/contracts/src/index.ts"],
      "@repo/contracts/*": ["../../packages/contracts/src/*"],
      "@repo/env": ["../../packages/env/src/index.ts"],
      "@repo/env/api": ["../../packages/env/src/api.env.ts"],
      "@repo/env/web": ["../../packages/env/src/web.env.ts"],
      "@repo/database": ["../../packages/database/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"],
  "ts-node": {
    "transpileOnly": true,
    "files": true
  }
}
